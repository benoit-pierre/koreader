 #include "pix_internal.h"
@@ -129,13 +130,17 @@
 #if  HAVE_LIBPNG   /* defined in environ.h */
 /* --------------------------------------------*/
 
-#include "png.h"
+#include "spng.h"
 
+#if 0
 #if  HAVE_LIBZ
 #include "zlib.h"
 #else
 #define  Z_DEFAULT_COMPRESSION (-1)
