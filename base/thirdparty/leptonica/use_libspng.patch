 /* ------------------ Set default for read option -------------------- */
     /* Strip 16 bpp --> 8 bpp on reading png; default is for stripping.
@@ -148,6 +153,451 @@ static l_int32   var_PNG_STRIP_16_TO_8 = 1;
 #endif  /* ~NO_CONSOLE_IO */
 
 
+#ifdef NO_CONSOLE_IO
+# define SPNG_STRERROR(E)  ""
+#else
+# define SPNG_STRERROR(E)  spng_strerror(E)
+#endif
+
+static l_ok
+_pixWritePng(FILE       *fp,
+             l_uint8   **pfiledata,
+             size_t     *pfilesize,
+             PIX        *pix,
+             l_float32   gamma)
+{
+l_int32           d, spp, valid;
+PIXCMAP          *cmap;
+struct spng_ihdr  ihdr;
+struct spng_phys  phys;
+spng_ctx         *ctx;
+int               err;
+
+    if (!pix)
+        return ERROR_INT("pix not defined", __func__, 1);
+
+    d = pixGetDepth(pix);
+    spp = pixGetSpp(pix);
+
+    ihdr.width = pixGetWidth(pix);
+    ihdr.height = pixGetHeight(pix);
+    ihdr.compression_method = 0;
+    ihdr.filter_method = 0;
+    ihdr.interlace_method = 0;
+
+        /* Do not set pad bits for d = 24 ! */
+    if (d != 24) pixSetPadBits(pix, 0);
+
+        /* Set the color type and bit depth. */
+    if (d == 32 && spp == 4) {
+        ihdr.bit_depth = 8;
+        ihdr.color_type = SPNG_COLOR_TYPE_TRUECOLOR_ALPHA;
+        cmap = NULL;
+    } else if (d == 24 || d == 32) {
+        ihdr.bit_depth = 8;
+        ihdr.color_type = SPNG_COLOR_TYPE_TRUECOLOR;
+        cmap = NULL;
+    } else {
+        ihdr.bit_depth = d;
+        cmap = pixGetColormap(pix);
+        ihdr.color_type = cmap ? SPNG_COLOR_TYPE_INDEXED : SPNG_COLOR_TYPE_GRAYSCALE;
+    }
+
+    /* fprintf(stderr, "%s: %d×%d, d=%d, spp=%d, cmflag=%d\n", __func__, ihdr.width, ihdr.height, d, spp, cmflag); */
+    /* pixWrite("write.pnm", pix, IFF_PNM); */
+
+#if  DEBUG_WRITE
+    lept_stderr("cmflag = %d, bit_depth = %d, color_type = %d\n",
+                cmflag, ihdr.bit_depth, ihdr.color_type);
+#endif  /* DEBUG_WRITE */
+
+    ctx = spng_ctx_new(SPNG_CTX_ENCODER);
+    if (!ctx)
+        return ERROR_INT("spng_ctx_new failed", __func__, 1);
+
+    if (fp) {
+        err = spng_set_png_file(ctx, fp);
+    } else {
+        err = spng_set_option(ctx, SPNG_ENCODE_TO_BUFFER, 1);
+    }
+    if (err) {
+        err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+        goto end;
+    }
+
+    {
+        l_int32 compval = Z_DEFAULT_COMPRESSION;
+        if (pix->special >= 10 && pix->special < 20)
+            compval = pix->special - 10;
+        err = spng_set_option(ctx, SPNG_IMG_COMPRESSION_LEVEL, 5);
+        if (err) {
+            err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+            goto end;
+        }
+    }
+
+    err = spng_set_ihdr(ctx, &ihdr);
+    if (err) {
+        err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+        goto end;
+    }
+
+        /* Store resolution in ppm, if known */
+    phys.ppu_x = (uint32_t)(39.37 * (l_float32)pixGetXRes(pix) + 0.5);
+    phys.ppu_y = (uint32_t)(39.37 * (l_float32)pixGetYRes(pix) + 0.5);
+    if ((phys.ppu_x == 0) || (phys.ppu_y == 0))
+        phys.unit_specifier = 0; // pixels/unknown
+    else
+        phys.unit_specifier = 1; // pixels/metter
+    err = spng_set_phys(ctx, &phys);
+    if (err) {
+        err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+        goto end;
+    }
+
+        /* Make and save the palette */
+    if (cmap) {
+        int              opaque;
+        struct spng_plte plte;
+        struct spng_trns trns;
+
+        trns.gray = 0;
+        trns.red = 0;
+        trns.green = 0;
+        trns.blue = 0;
+        trns.n_type3_entries = 0;
+
+        plte.n_entries = pixcmapGetCount(cmap);
+        if (plte.n_entries > 256) {
+            err = ERROR_INT("colormap depth > 8 not supported", __func__, 1);
+            goto end;
+        }
+
+        for (uint32_t n = 0; n < plte.n_entries; ++n) {
+            l_int32 rval, gval, bval, aval;
+            pixcmapGetRGBA(cmap, n, &rval, &gval, &bval, &aval);
+            plte.entries[n].red = rval;
+            plte.entries[n].green = gval;
+            plte.entries[n].blue = bval;
+            if (aval != 255)
+                trns.type3_alpha[trns.n_type3_entries++] = aval;
+        }
+
+        err = spng_set_plte(ctx, &plte);
+        if (err) {
+            err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+            goto end;
+        }
+
+            /* Add the tRNS chunk.  If the non-opaque colors are listed
+             * first in the colormap, as in the spec, we can use that in
+             * the 4th arg of png_set_tRNS.  Otherwise, transparency will
+             * be lost for some colors.  To prevent that, see the comments
+             * in pixcmapNonOpaqueColorsInfo(). */
+        if (trns.n_type3_entries) {  /* alpha channel has some transparency; assume valid */
+            err = spng_set_trns(ctx, &trns);
+            if (err) {
+                err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+                goto end;
+            }
+        }
+    }
+
+        /* 0.4545 is treated as the default by some image
+         * display programs (not gqview).  A value > 0.4545 will
+         * lighten an image as displayed by xv, display, etc. */
+    if (gamma > 0.0) {
+        err = spng_set_gama(ctx, gamma);
+        if (err) {
+            err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+            goto end;
+        }
+    }
+
+    {
+        char *t = pixGetText(pix);
+        if (t) {
+            struct spng_text text = {
+                .keyword = "Comment",
+                .type = SPNG_TEXT,
+                .length = strlen(t),
+                .text = t,
+            };
+            err = spng_set_text(ctx, &text, 1);
+            if (err) {
+                err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+                goto end;
+            }
+        }
+    }
+
+    err = spng_encode_image(ctx, NULL, 0, SPNG_FMT_PNG, SPNG_ENCODE_PROGRESSIVE | SPNG_ENCODE_FINALIZE);
+    if (err) {
+        err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+        goto end;
+    }
+
+    if ((d != 32) && (d != 24)) {  /* not rgb color */
+            /* Generate a temporary pix with bytes swapped.
+             * For writing a 1 bpp image as png:
+             *    ~ if no colormap, invert the data, because png writes
+             *      black as 0
+             *    ~ if colormapped, do not invert the data; the two RGBA
+             *      colors can have any value.  */
+        PIX *pix1;
+        if (d == 1 && !cmap) {
+            pix1 = pixInvert(NULL, pix);
+            pixEndianByteSwap(pix1);
+        } else {
+            pix1 = pixEndianByteSwapNew(pix);
+        }
+        if (!pix1) {
+            err = ERROR_INT("pix1 not made", __func__, 1);
+            goto end;
+        }
+
+            /* Transfer the data */
+        l_int32 wpl = pixGetWpl(pix1);
+        l_uint32 *data = pixGetData(pix1);
+        for (int y = 0; y < ihdr.height; y++) {
+            err = spng_encode_row(ctx, data + y * wpl, wpl * 4);
+            if (err && err != SPNG_EOI && y == ihdr.height - 1) {
+                err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+                goto end;
+            }
+        }
+
+        pixDestroy(&pix1);
+    }
+    else {
+        /* For rgb and rgba, compose and write a row at a time */
+        l_uint32 *data = pixGetData(pix);
+        l_int32 wpl = pixGetWpl(pix);
+        if (d == 24) {  /* See note 7 in pixWriteStreamPng() */
+            for (int y = 0; y < ihdr.height; y++) {
+                err = spng_encode_row(ctx, data + y * wpl, ihdr.width * 3);
+                if (err && err != SPNG_EOI && y == ihdr.height - 1) {
+                    err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+                    goto end;
+                }
+            }
+        } else {  /* 32 bpp rgb and rgba.  If spp = 4, write the alpha channel */
+            uint8_t *rowbuffer = LEPT_CALLOC(ihdr.width, 4);
+            for (int y = 0; y < ihdr.height; y++) {
+                l_uint32 *ppixel = data + y * wpl;
+                uint8_t *p = rowbuffer;
+                for (int x = 0; x < ihdr.width; ++x) {
+                    *p++ = GET_DATA_BYTE(ppixel, COLOR_RED);
+                    *p++ = GET_DATA_BYTE(ppixel, COLOR_GREEN);
+                    *p++ = GET_DATA_BYTE(ppixel, COLOR_BLUE);
+                    if (spp == 4)
+                        *p++ = GET_DATA_BYTE(ppixel, L_ALPHA_CHANNEL);
+                    ppixel++;
+                }
+
+                err = spng_encode_row(ctx, rowbuffer, spp * ihdr.width);
+                if (err && err != SPNG_EOI && y == ihdr.height - 1) {
+                    err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+                    goto end;
+                }
+            }
+            LEPT_FREE(rowbuffer);
+        }
+    }
+
+    if (!fp) {
+        *pfiledata = spng_get_png_buffer(ctx, pfilesize, &err);
+        if (err) {
+            err = ERROR_INT(SPNG_STRERROR(err), __func__, 1);
+            goto end;
+        }
+    }
+
+    err = 0;
+
+end:
+    spng_ctx_free(ctx);
+
+    return err;
+}
+
+PIX *
+_pixReadPng(FILE *fp, const l_uint8 *filedata, size_t filesize)
+{
+l_int32           d, spp;
+PIXCMAP          *cmap;
+struct spng_ihdr  ihdr;
+enum spng_format  fmt;
+spng_ctx         *ctx;
+int               err;
+PIX              *pix;
+PIX              *ret;
+
+    pix = ret = NULL;
+    cmap = NULL;
+
+    ctx = spng_ctx_new(0);
+    if (!ctx)
+        return ERROR_PTR("spng_ctx_new failed", __func__, NULL);
+
+    err = fp ? spng_set_png_file(ctx, fp) : spng_set_png_buffer(ctx, filedata, filesize);
+    if (err) {
+        ret = ERROR_PTR(SPNG_STRERROR(err), __func__, NULL);
+        goto end;
+    }
+
+    err = spng_get_ihdr(ctx, &ihdr);
+    if (err) {
+        ret = ERROR_PTR(SPNG_STRERROR(err), __func__, NULL);
+        goto end;
+    }
+
+    if (ihdr.bit_depth > 8) {
+        ret = ERROR_PTR("not bit depth > 8 is unsupported", __func__, NULL);
+        goto end;
+    }
+
+    switch (ihdr.color_type) {
+    case SPNG_COLOR_TYPE_GRAYSCALE:
+        d = ihdr.bit_depth;
+        spp = 1;
+        fmt = SPNG_FMT_PNG;
+        break;
+    case SPNG_COLOR_TYPE_TRUECOLOR:
+        d = 32;
+        spp = 3;
+        fmt = SPNG_FMT_RGBA8;
+        break;
+    case SPNG_COLOR_TYPE_INDEXED:
+        {
+            struct spng_trns trns;
+            if (spng_get_trns(ctx, &trns)) {
+                // No transparency.
+                d = ihdr.bit_depth;
+                spp = 1;
+                fmt = SPNG_FMT_PNG;
+            }
+            else {
+                // Transparency: convert to RGBA.
+                L_INFO("converting %d bpp cmap with alpha ==> RGBA\n", __func__, ihdr.bit_depth);
+                d = 32;
+                spp = 4;
+                fmt = SPNG_FMT_RGBA8;
+            }
+        }
+        break;
+    case SPNG_COLOR_TYPE_GRAYSCALE_ALPHA:
+        L_INFO("converting (gray + alpha) ==> RGBA\n", __func__);
+        d = 32;
+        spp = 4;
+        fmt = SPNG_FMT_RGBA8;
+        break;
+    case SPNG_COLOR_TYPE_TRUECOLOR_ALPHA:
+        d = 32;
+        spp = 4;
+        fmt = SPNG_FMT_RGBA8;
+        break;
+    default:
+        assert(0);
+        ret = ERROR_PTR("invalid color type", __func__, NULL);
+        goto end;
+    }
+
+    /* fprintf(stderr, "%s: %d×%d, d=%d, spp=%d, fmt=%d\n", __func__, ihdr.width, ihdr.height, d, spp, fmt); */
+
+    cmap = NULL;
+    if (ihdr.color_type == SPNG_COLOR_TYPE_INDEXED && fmt == SPNG_FMT_PNG) {
+        struct spng_plte plte;
+        err = spng_get_plte(ctx, &plte);
+        if (err) {
+            ret = ERROR_PTR(SPNG_STRERROR(err), __func__, NULL);
+            goto end;
+        }
+        cmap = pixcmapCreate(d);
+        for (uint32_t n = 0; n < plte.n_entries; ++n)
+            pixcmapAddColor(cmap, plte.entries[n].red, plte.entries[n].green, plte.entries[n].blue);
+    }
+
+    if ((pix = pixCreate(ihdr.width, ihdr.height, d)) == NULL) {
+        ret = ERROR_PTR("pix not made", __func__, NULL);
+        goto end;
+    }
+    pixSetInputFormat(pix, IFF_PNG);
+    l_int32 wpl = pixGetWpl(pix);
+    l_uint32 *data = pixGetData(pix);
+    pixSetSpp(pix, spp);
+    if (cmap && pixSetColormap(pix, cmap)) {
+        ret = ERROR_PTR("invalid colormap", __func__, NULL);
+        goto end;
+    }
+
+    err = spng_decode_image(ctx, NULL, 0, fmt, SPNG_DECODE_PROGRESSIVE | SPNG_DECODE_TRNS);
+    if (err) {
+        ret = ERROR_PTR(SPNG_STRERROR(err), __func__, NULL);
+        goto end;
+    }
+
+    for (;;) {
+        struct spng_row_info row_info;
+        err = spng_get_row_info(ctx, &row_info);
+        if (err)
+            break;
+        l_uint32 *ppixel = data + row_info.row_num * wpl;
+        err = spng_decode_row(ctx, ppixel, wpl * 4);
+        if (err)
+            break;
+    }
+    if (err != SPNG_EOI) {
+        ret = ERROR_PTR(SPNG_STRERROR(err), __func__, NULL);
+        goto end;
+    }
+
+        /* Get the resolution if there is any */
+    {
+        struct spng_phys phys;
+
